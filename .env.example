# TradeStation API credentials — copy to .env and fill in.
#
#   cp .env.example .env
#   # edit .env, paste your values
#
# These env vars are read by tradestation.TradeStationClient.from_env()
# and by scripts/fetch_v3_spec.py. They mirror the field names documented
# in docs/02-auth-and-credentials.md.
#
# DO NOT commit .env. It is in .gitignore.

# From the TradeStation developer dashboard.
TS_CLIENT_ID=
TS_CLIENT_SECRET=

# A long-lived refresh token, obtained via the Auth Code Flow (browser).
# Once set, the library will use this to mint short-lived access tokens
# automatically (20-minute lifetime, proactively refreshed).
TS_REFRESH_TOKEN=

# Environment: "live" for real money, "sim" for paper trading.
TS_ENV=live

# OAuth scopes. The default below is what most users want.
# Must include `offline_access` to receive refresh tokens.
TS_SCOPE="openid profile MarketData ReadAccount Trade Matrix Crypto OptionSpreads offline_access"
